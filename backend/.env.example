# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored — never commit real credentials.

# ─── SFTP backup fetch (optional) ─────────────────────────────
# Used by /api/sftp-download to pull a station's latest backup
# from the OSS server. Leave blank to disable that endpoint.
SFTP_HOST=10.0.0.1
SFTP_PORT=22
SFTP_USERNAME=replace-me
SFTP_PASSWORD=replace-me
SFTP_REMOTE_DIR=/path/to/mrbts/backups

# ─── ngrok share profile (optional) ───────────────────────────
# Required only when running `docker-compose --profile share up`.
# Get a free token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# ─── Flask runtime (optional — defaults shown) ────────────────
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
# FLASK_DEBUG=true
# MAX_UPLOAD_MB=50
# UPLOAD_FOLDER=uploads
# GENERATED_FOLDER=generated
# EXAMPLE_FILES_FOLDER=example_files
